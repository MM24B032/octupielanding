# Waitlist webhook forward. Set these to wire /api/waitlist to Google
# Sheets (or Zapier, Make, n8n, any HTTPS endpoint that accepts JSON POST).
#
# See docs/WAITLIST_SETUP.md for the full Google Sheets setup walk-through.

# The deployed Apps Script Web App URL (or any HTTPS webhook).
WAITLIST_WEBHOOK_URL=

# Shared secret sent in the POST body as `secret`. Must match the value
# inside the Apps Script. Use a long random string. Do NOT share.
WAITLIST_WEBHOOK_SECRET=

# Optional. When set, GET /api/waitlist returns the local JSON count
# if the request carries header x-admin-token: <this value>. Returns 404
# when unset.
WAITLIST_ADMIN_TOKEN=

# Optional. Override the local JSON fallback file path. Leave blank
# for the default (/tmp/octupie-waitlist.json or ./.data/waitlist.json).
WAITLIST_FILE=
